# PostgreSQL Database configuration
POSTGRES_USER=janus
POSTGRES_PASSWORD=janus_pass
POSTGRES_DB=janus_db

# Backend Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# External APIs
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone VectorDB configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=your_pinecone_env_here

# Google Calendar Tool 
GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials_here

# Messenger Tool
MESSENGER_API_KEY=your_messenger_api_key_here

# Weather Tool
WEATHER_API_KEY=your_weather_api_key_here

# Frontend Configuration
NUXT_PUBLIC_API_BASE=http://localhost:5000

# Mobile (Expo) Configuration
# Use your machine IP when testing on a physical device (e.g. http://192.168.1.x:5000/api/v1)
EXPO_PUBLIC_API_BASE=http://localhost:5000/api/v1
